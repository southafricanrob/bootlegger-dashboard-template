# ----------------------------------------------------------------------------
# Copy this file to `.env` for local development and fill in the values.
# On Railway, set these as service variables instead (Settings -> Variables).
# Never commit a real `.env` file.
# ----------------------------------------------------------------------------

# --- App ---------------------------------------------------------------------
# Shown in the UI and in OTP emails.
APP_NAME="Bootlegger Dashboard"

# --- Database (SQLite via libSQL) --------------------------------------------
# Local dev: a file in ./data (created automatically).
# On Railway: point at the mounted volume, e.g. file:/data/app.db
DATABASE_URL="file:./data/app.db"

# --- Auth (better-auth) ------------------------------------------------------
# A long random secret used to sign sessions. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-generate-a-long-random-secret"
# The public URL the app is served from (no trailing slash).
# Local: http://localhost:3000  |  Railway: https://your-app.up.railway.app
BETTER_AUTH_URL="http://localhost:3000"

# --- Email (Resend) — used to deliver one-time sign-in codes ------------------
# Get an API key at https://resend.com. During development you can use your own
# Resend account + a domain you control (e.g. bootlegger.jemx.app), then swap to
# Bootlegger's account later by changing just RESEND_API_KEY and EMAIL_FROM.
# If RESEND_API_KEY is empty, sign-in codes are printed to the server logs
# instead of emailed (handy for local testing without Resend set up).
RESEND_API_KEY=""
# The From address. Its domain must be verified in the Resend account above.
EMAIL_FROM="Bootlegger Dashboard <noreply@bootlegger.jemx.app>"

# --- Access control ----------------------------------------------------------
# Comma-separated email domains allowed to sign in (no @, lowercase).
ALLOWED_DOMAINS="bootlegger.co.za,thesilogroup.co.za"
# Comma-separated emails seeded as admins on first boot. These people can sign
# in immediately and manage everyone else from Settings.
INITIAL_ADMIN_EMAILS="you@bootlegger.co.za"

# --- Microsoft SSO (OPTIONAL — dormant until filled in) ----------------------
# Leave blank to keep email-code sign-in only. When you create an Entra ID app
# registration, fill these in and the "Continue with Microsoft" button turns on
# automatically — no code change needed.
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
# "common" works for most multi-tenant setups; or use your specific tenant ID.
MICROSOFT_TENANT_ID="common"
